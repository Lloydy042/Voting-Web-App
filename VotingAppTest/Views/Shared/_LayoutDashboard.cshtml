<!DOCTYPE html>
<html>
<head>
   <div>
        <img src="~/pictures/cdm_logo.png" alt="CDM Logo" style="width:50px; height:50px; margin-right:10px;" />
        <title>CAST YOUR VOTE</title>


   </div>
    <title>Voting System Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            display: center;
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f9f9f9; 

        .sidebar {
            width: 250px;
            background: linear-gradient(180deg, #004d00, #006400);
            height: 100vh;
            color: #F0FFFF;
            padding: 20px;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            box-shadow: 2px 0 8px rgba(0,0,0,0.2);
            transition: width 0.3s ease;
        }

            .sidebar.collapsed {
                width: 70px;
                padding: 20px 10px;
            }

                .sidebar.collapsed h3 {
                    display:flex;
                }

                .sidebar.collapsed a span {
                    display: flex;
                }

            .sidebar a i {
                font-size: 1.2rem;
            }
            .sidebar h3 {
                font-weight: bold;
                margin-bottom: 15px;
                color: #F0FFFF;
            }


            .sidebar a {
                color: #c8e6c9;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px;
                text-decoration: none;
                border-radius: 8px;
                margin-bottom: 8px;
                font-weight: 500;
                transition: all 0.3s ease;
            }


                .sidebar a:hover {
                    background: #81c784;
                    color: #fff;
                    transform: translateX(5px);
                }

        .content {
            margin-left: 250px;
            padding: 30px;
            background: linear-gradient(135deg, #f9f9f9, #e8f5e9);
            transition: margin-left 0.3s ease;
            min-height: 100vh;
        }
      
            .content.expanded {
                margin-left: 70px;
            }
        .card {
            background: #fff;
            border-radius: 12px;
            margin-bottom: 20px;
            box-shadow: 0 6px 12px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            }

        .card-header {
            background-color: #a5d6a7; 
            color: #006400;
            font-weight: bold;
        }

        .btn-primary {
            background: linear-gradient(90deg, #43a047, #66bb6a);
            border: none;
            border-radius: 25px;
            padding: 8px 20px;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background: linear-gradient(90deg, #2e7d32, #43a047);
                box-shadow: 0 0 10px rgba(67,160,71,0.5);
            }

        .btn-secondary {
            background-color: #9e9e9e; 
            border: none;
        }

        .btn-danger {
            background-color: #ef5350; 
            border: none;
        }
        .toggleSidebar{
            position:fixed;
        }
    </style>
</head>
<body>
    <nav class="sidebar d-flex flex-column" id="sidebar">
       
        <div class="d-flex align-items-center mb-3">
            <img src="~/pictures/cdm_logo.png" alt="CDM Logo" class="img-fluid" style="width:40px; height:40px;" />
            <h3 class="ms-2 mb-0">Cast Your Votes Now</h3>
            
        </div>
        @* <button class="btn btn-secondary mb-3" id="toggleSidebar">☰</button> *@
        <hr />
        <a href="/Dashboard/Index"><i class="bi bi-speedometer2"></i> <span>Dashboard</span></a>
        <a href="/Candidates/Index"><i class="bi bi-people"></i> <span>Candidates</span></a>
        <a asp-controller="Home" asp-action="MyResults"><i class="bi bi-bar-chart"></i> <span>Voting Summary</span></a>
        @if (Context.Session.GetString("Role") == "Admin")
        {
            <a href="/Votes/VoterStats"><i class="bi bi-bar-chart"></i> <span>Voters Statistics</span></a>
            <a href="/Home/ManageUsers"><i class="bi bi-bar-chart"></i> <span>Manage Users</span></a>
        }

        <a href="/Home/Logout" class="mt-3 text-danger"><i class="bi bi-box-arrow-right"></i> <span>Logout</span></a>
       
       
       
       
      
      
    </nav>   

    <div class="content">
        <button class="btn btn-secondary mb-3 d-md-none" id="toggleSidebar">☰ Menu</button>
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $('#toggleSidebar').on('click', function () {
            $('#sidebar').toggleClass('d-none');
        });
    </script>

</body>
</html>