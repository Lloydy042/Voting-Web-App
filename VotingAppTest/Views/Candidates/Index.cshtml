<!-- Extra Info -->
<div class="card mt-4 shadow-sm tip-card">
    <div class="card-body">
        <h5 class="fw-bold"><i class="bi bi-lightbulb"></i> Tip for Voters</h5>
        <p class="text-muted">
            Click “View Profile” to learn more about each candidate’s background,
            vision, and plans for the student council. Make an informed choice!
        </p>
    </div>
</div>