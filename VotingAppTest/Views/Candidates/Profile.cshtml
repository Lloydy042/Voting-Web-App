@model Candidate
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<!-- Candidate Profile Card -->
<div class="card shadow-lg mb-4 border-success" style="border-radius: 12px;">
    <div class="card-header text-center" style="background:#0C4E35; color:#fff; border-radius:12px 12px 0 0;">
        @if (Model.ImageData != null && Model.ImageData.Length > 0)
        {
            var base64 = Convert.ToBase64String(Model.ImageData);
            var imgSrc = $"data:image/png;base64,{base64}";
            <img src="@imgSrc" alt="@Model.FullName"
                 class="img-thumbnail mb-3"
                 style="width:150px; height:150px; object-fit:cover; border-radius:50%; border:3px solid #fff;" />
        }

        <h3 class="fw-bold mb-0">@Model.FullName</h3>
        <p class="text-light mb-0">@Model.Position</p>
        <small class="text-light">
            <span class="badge bg-warning text-dark">@Model.Category</span>

            @Model.Course - Section @Model.Section | Year @Model.YearLevel
        </small>
    </div>

    <div class="card-body">
        <h5 class="fw-bold text-success">About</h5>
        <p>@Model.Description</p>

        @if (!string.IsNullOrEmpty(Model.Vision))
        {
            <h5 class="fw-bold text-success mt-3">Vision</h5>
            <p>@Model.Vision</p>
        }

        @if (!string.IsNullOrEmpty(Model.Plans))
        {
            <h5 class="fw-bold text-success mt-3">Plans</h5>
            <p>@Model.Plans</p>
        }

        @if (Model.QrCode != null)
        {
            <div class="text-center mt-4">
                <img src="data:image/png;base64,@Convert.ToBase64String(Model.QrCode)"
                     alt="QR Code for @Model.FullName"
                     class="img-fluid shadow-sm"
                     style="max-height:200px; border:2px solid #0C4E35; border-radius:8px;" />
                <p class="text-muted mt-2">📱 Scan to view this profile</p>
            </div>
        }
    </div>
</div>

<!-- Admin Controls -->
@if (Context.Session.GetString("Role") == "Admin")
{
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-success">
            <i class="fas fa-edit"></i> Edit
        </a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline;">
            <button type="submit" class="btn btn-outline-danger"
                    onclick="return confirm('Are you sure you want to delete this candidate?');">
                <i class="fas fa-trash"></i> Delete
            </button>
        </form>
    </div>
}

<!-- Back Button -->
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">⬅ Back to Candidates</a>
</div>

<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>