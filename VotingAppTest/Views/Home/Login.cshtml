@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>CDM Voting System - Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            background: #FFFAF0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Arial, sans-serif;
            overflow: hidden;
        }

        
        .bg-waves {
            position: absolute;
            width: 100%;
            height: 100%;
            background: url('/images/bg_waves.png');
            background-size: cover;
            opacity: 0.12;
            z-index: -1;
            filter: blur(2px);
        }

        .login-wrapper {
            width: 100%;
            max-width: 420px;
            text-align: center;
        }

        .header-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
            margin-left: -15px; 
        }

            .header-logo img {
                width: 70px;
                margin-right: 10px;
            }

        .header-logo-text {
            text-align: left;
        }

            .header-logo-text h2 {
                margin: 0;
                font-size: 28px;
                font-weight: bold;
                color: #0C4E35;
            }

            .header-logo-text p {
                margin: 0;
                font-size: 12px;
                letter-spacing: 1px;
                color: #2d4b62;
            }

        .login-card {
            background: #ffffff;
            padding: 30px 28px;
            border-radius: 12px;
            border: 1px solid #e5e5e5;
            box-shadow: 0px 4px 18px rgba(0,0,0,0.08);
        }

        .form-control {
            height: 45px;
            border-radius: 8px;
        }

        .label-text {
            float: left;
            margin-bottom: 4px;
            font-size: 14px;
            font-weight: 600;
            color: #333;
        }

        .btn-login {
            background: #1FA64A;
            border: none;
            padding: 10px;
            font-size: 16px;
            border-radius: 8px;
            color: white;
            width: 100%;
        }

            .btn-login:hover {
                background: #168e3e;
            }

        .admin-link {
            color: #0066cc;
            text-decoration: none;
        }

    </style>
</head>
<body>

    <div class="bg-waves"></div>

    <div class="login-wrapper">

       
        <div class="header-logo">
            <img src="/pictures/cdm_logo.png" alt="CDM Logo" />
            <div class="header-logo-text">
                <h2>CdM</h2>
                <p>COLEGIO DE MONTALBAN</p>
            </div>
        </div>

        <div class="login-card">

            <form method="post">
                <label class="label-text">Student ID</label>
                <input name="studentId" class="form-control mb-3" placeholder="Enter your student ID" required />

              

                <label class="label-text">Password</label>
                <input name="password" type="password" class="form-control mb-4" placeholder="Enter your password" required />
            

                <button class="btn btn-login">Login to Vote</button>
            </form>
            <a href="/Home/ForgotPassword" class="admin-link">Forgot Password?</a>
            @if (ViewBag.ShowVerifyButton != null && (bool)ViewBag.ShowVerifyButton)
            {
                <form asp-action="Verify" method="get">
                    <button type="submit" class="btn btn-outline-primary mt-3">Verify Email</button>
                </form>
            }

            @if (ViewBag.Error != null)
            {
                <p class="text-danger mt-3">@ViewBag.Error</p>
            }

            <p class="text-muted mt-3 mb-1">Or</p>

            <a href="/Home/Register" class="admin-link">Register</a>
        </div>

    </div>
    <script>
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>

</body>
</html>
