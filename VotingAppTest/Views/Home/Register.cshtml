@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>CDM Voting System - Register</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #FFFAF0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            font-family: Arial, sans-serif;
            overflow-y: auto;
            padding: 30px 15px;
        }

        .bg-waves {
            position: absolute;
            width: 100%;
            height: 100%;
            background: url('/images/bg_waves.png');
            background-size: cover;
            opacity: 0.12;
            z-index: -1;
            filter: blur(2px);
        }

        .register-wrapper {
            width: 100%;
            max-width: 420px;
            text-align: center;
        }

        .header-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
            margin-left: -15px;
        }

            .header-logo img {
                width: 70px;
                margin-right: 10px;
            }

        .header-logo-text {
            text-align: left;
        }

            .header-logo-text h2 {
                margin: 0;
                font-size: 28px;
                font-weight: bold;
                color: #0C4E35;
            }

            .header-logo-text p {
                margin: 0;
                font-size: 12px;
                letter-spacing: 1px;
                color: #2d4b62;
            }

        .register-card {
            background: #ffffff;
            padding: 30px 28px;
            border-radius: 12px;
            border: 1px solid #e5e5e5;
            box-shadow: 0px 4px 18px rgba(0,0,0,0.08);
        }

        .form-control {
            height: 45px;
            border-radius: 8px;
        }

        .label-text {
            float: left;
            margin-bottom: 4px;
            font-size: 14px;
            font-weight: 600;
            color: #333;
        }

        .btn-register {
            background: #1FA64A;
            border: none;
            padding: 10px;
            font-size: 16px;
            border-radius: 8px;
            color: white;
            width: 100%;
        }

            .btn-register:hover {
                background: #168e3e;
            }

        .back-link {
            color: #0066cc;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="bg-waves"></div>

    <div class="register-wrapper" >

        <!-- Logo Header -->
        <div class="header-logo">
            <img src="/pictures/cdm_logo.png" alt="CDM Logo" />
            <div class="header-logo-text">
                <h2>CDM</h2>
                <p>COLEGIO DE MONTALBAN</p>
            </div>
        </div>

        <div class="register-card">
            <h4 class="mb-3">Create Account</h4>

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label class="label-text">Student ID</label>
                    <input name="studentId" class="form-control mb-2" placeholder="e.g., 23-12345" required />
                </div>
                <div class="mb-3">
                    <label class="label-text">Email</label>
                    <input name="email" type="email" class="form-control mb-3" placeholder="Email" required />
                </div>
                <div class="mb-3">
                    <label class="label-text">Password</label>
                    <input name="password" type="password" class="form-control mb-2" placeholder="Password" required />
                    <small class="text-muted">
                        Minimum 8 characters, including at least one uppercase, one lowercase, one number, and one special character.
                    </small>
                </div>

                <!-- New Academic Fields -->
                <div class="mb-3">
                    <label class="label-text">Course</label>
                    <select name="course" class="form-select">
                        <option value="BSCPE">BSCPE</option>
                        <option value="BSIT">BSIT</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="label-text">Section</label>
                    <select name="section" class="form-select">
                        <option value="A">A</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="label-text">Year Level</label>
                    <select name="yearLevel" class="form-control mb-3" required>
                        <option value="1">1st Year</option>
                        <option value="2">2nd Year</option>
                        <option value="3">3rd Year</option>
                        <option value="4">4th Year</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="label-text">Role</label>
                    <select name="role" class="form-control mb-3">
                        <option value="Voter">Voter</option>
                        @* <option value="Admin">Admin</option> *@
                    </select>
                </div>

                <button class="btn btn-register">Register</button>
            </form>

            @if (ViewBag.Error != null)
            {
                <p class="text-danger mt-3">@ViewBag.Error</p>
            }
            @if (ViewBag.Success != null)
            {
                <p class="text-success mt-3">@ViewBag.Success</p>
            }

            <div class="text-center mt-3">
                <a href="/Home/Login" class="back-link">Back to Login</a>
            </div>
        </div>

    </div>

    <script>
        document.querySelector("form").addEventListener("submit", function(e) {
            const studentId = document.querySelector("[name='studentId']").value;
            const pattern = /^\d{2}-\d{5}$/;
            if (!pattern.test(studentId)) {
                alert("Invalid Student ID format. Use YY-XXXXX (e.g., 23-12345).");
                e.preventDefault();
            }
        });
    </script>
    <script>
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>
</body>
</html>