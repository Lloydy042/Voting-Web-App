@model IEnumerable<VotingAppTest.Models.User>
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="fas fa-users"></i> User Management</h3>
            <a asp-controller="Home" asp-action="AddUser" class="btn btn-light btn-sm">
                <i class="fas fa-user-plus"></i> Add User
            </a>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover align-middle">
                <thead style="background-color:#0C4E35; color:white;">
                    <tr>
                        <th>Student ID</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Verified</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.StudentId</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-success" : "bg-secondary")">
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                <span class="badge @(user.IsVerified ? "bg-success" : "bg-warning text-dark")">
                                    @(user.IsVerified ? "Yes" : "No")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-controller="Home" asp-action="EditUser" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-success">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>

                                    @if (user.Role != "Admin")
                                    {
                                        <form asp-controller="Home" asp-action="PromoteToAdmin" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="fas fa-arrow-up"></i> Make Admin
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-controller="Home" asp-action="DemoteToStudent" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning text-dark">
                                                <i class="fas fa-arrow-down"></i> Demote
                                            </button>
                                        </form>
                                    }

                                    <form asp-controller="Home" asp-action="DeleteUser" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>