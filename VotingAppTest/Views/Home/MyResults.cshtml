@model IEnumerable<VotingAppTest.Models.Candidate>

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <title>My Voting Summary - CDM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #f9f9f9;
            font-family: Arial, sans-serif;
        }

        .results-wrapper {
            max-width: 800px;
            margin: 50px auto;
            background: #fff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0px 4px 18px rgba(0,0,0,0.08);
        }

        .header-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }

            .header-logo img {
                width: 70px;
                margin-right: 10px;
            }

        .header-logo-text h2 {
            margin: 0;
            font-size: 28px;
            font-weight: bold;
            color: #0C4E35;
        }

        .header-logo-text p {
            margin: 0;
            font-size: 12px;
            letter-spacing: 1px;
            color: #2d4b62;
        }

        .candidate-card {
            border: 1px solid #e5e5e5;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }

            .candidate-card img {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                margin-right: 15px;
                object-fit: cover;
            }

        .candidate-info h5 {
            margin: 0;
            font-size: 18px;
            font-weight: bold;
        }

        .candidate-info p {
            margin: 0;
            color: #555;
        }
    </style>
</head>
<body>
    <div class="results-wrapper">
        <!-- Logo Header -->
        <div class="header-logo">
            <img src="/pictures/cdm_logo.png" alt="CDM Logo" />
            <div class="header-logo-text">
                <h2>CDM</h2>
                <p>COLEGIO DE MONTALBAN</p>
            </div>
        </div>

        <h4 class="mb-4 text-center">🗳️ My Voting Summary</h4>

        <!-- 🏛️ Student Council Votes -->
        <h5 class="fw-bold text-primary mb-3">Student Council Votes</h5>
        @if (!(ViewBag.CouncilVotes as List<Candidate>).Any())
        {
            <p class="text-muted">No Student Council votes yet.</p>
        }
        else
        {
            foreach (var candidate in (List<Candidate>)ViewBag.CouncilVotes)
            {
                <div class="candidate-card">
                    @if (candidate.ImageData != null && candidate.ImageData.Length > 0)
                    {
                        var base64 = Convert.ToBase64String(candidate.ImageData);
                        var imgSrc = $"data:image/png;base64,{base64}";
                        <img src="@imgSrc" alt="@candidate.FullName" />
                    }
                    else
                    {
                        <img src="/pictures/candidates/default.png" alt="Default" />
                    }
                    <div class="candidate-info">
                        <h5>@candidate.FullName</h5>
                        <p>@candidate.Position</p>
                    </div>
                </div>
            }
        }

        <!-- 👩‍🏫 Local Group Votes -->
        <h5 class="fw-bold text-success mt-4 mb-3">Class Officers Votes</h5>
        @if (!(ViewBag.LocalVotes as List<Candidate>).Any())
        {
            <p class="text-muted">No Class Officers votes yet.</p>
        }
        else
        {
            foreach (var candidate in (List<Candidate>)ViewBag.LocalVotes)
            {
                <div class="candidate-card">
                    @if (candidate.ImageData != null && candidate.ImageData.Length > 0)
                    {
                        var base64 = Convert.ToBase64String(candidate.ImageData);
                        var imgSrc = $"data:image/png;base64,{base64}";
                        <img src="@imgSrc" alt="@candidate.FullName" />
                    }
                    else
                    {
                        <img src="/pictures/candidates/default.png" alt="Default" />
                    }
                    <div class="candidate-info">
                        <h5>@candidate.FullName</h5>
                        <p>@candidate.Position</p>
                        <small>@candidate.Course - Section @candidate.Section | Year @candidate.YearLevel</small>
                    </div>
                </div>
            }
        }
    </div>
</body>
</html>